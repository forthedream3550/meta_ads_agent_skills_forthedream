# Server
MCP_TRANSPORT=stdio
LOG_LEVEL=info

# Safety. Keep disabled until tests and approvals are in place.
META_ADS_WRITE_ENABLED=false
META_ADS_DRY_RUN=true
META_ADS_APPROVAL_SECRET=replace-with-a-long-random-secret
META_ADS_AUDIT_LOG_PATH=./data/audit-log.jsonl

# Provider: dry-run or graph-api
META_ADS_PROVIDER=dry-run

# Required only for the Graph API provider.
META_ACCESS_TOKEN=
META_GRAPH_API_VERSION=
META_AD_ACCOUNT_ID=

# Optional guardrails. Values are examples, not universal advertising advice.
MAX_BUDGET_INCREASE_PERCENT=10
MAX_BUDGET_DECREASE_PERCENT=20
MAX_CUMULATIVE_BUDGET_CHANGE_24H_PERCENT=20
